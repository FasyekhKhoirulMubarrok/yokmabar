# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME=YokMabar
APP_URL=https://yourdomain.com

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://yokmabar:secret@localhost:5432/topup_db
REDIS_URL=redis://localhost:6379

# ─── Bot Tokens ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_ADMIN_CHANNEL_ID=
FONNTE_API_KEY=
WHATSAPP_ADMIN_NUMBER=

# ─── Payment — Midtrans ──────────────────────────────────────────────────────
MIDTRANS_SERVER_KEY=
MIDTRANS_WEBHOOK_URL=https://yourdomain.com/webhook/midtrans

# ─── Supplier — Digiflazz ────────────────────────────────────────────────────
DIGIFLAZZ_USERNAME=
DIGIFLAZZ_API_KEY=
DIGIFLAZZ_WEBHOOK_SECRET=
DIGIFLAZZ_MIN_BALANCE=50000

# ─── Sistem Poin ─────────────────────────────────────────────────────────────
POINT_EXPIRY_DAYS=90
POINT_RATE=2000
POINT_REDEEM_UNIT=200
POINT_REDEEM_VALUE=1000

# ─── Sistem Referral Discord ──────────────────────────────────────────────────
REFERRAL_BONUS_POINTS=50

# ─── Markup Harga ─────────────────────────────────────────────────────────────
PRICE_MARKUP_RATE=0.03

# ─── Development Only ─────────────────────────────────────────────────────────
# Set guild ID untuk deploy slash command instan ke server tertentu (testing).
# Kosongkan saat production agar command terdaftar secara global.
DISCORD_TEST_GUILD_ID=

# ─── PostgreSQL (untuk docker-compose) ───────────────────────────────────────
POSTGRES_USER=yokmabar
POSTGRES_PASSWORD=secret
POSTGRES_DB=topup_db
