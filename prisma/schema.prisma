generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(uuid())
  platform        Platform
  platformUserId  String
  username        String?
  createdAt       DateTime         @default(now())
  orders          Order[]
  points          Point[]
  serverReferrals ServerReferral[]
  feedbacks       Feedback[]

  @@unique([platform, platformUserId])
}

model Product {
  id           String   @id @default(uuid())
  brand        String
  category     String
  itemCode     String   @unique
  itemName     String
  basePrice    Int      @default(0)
  price        Int
  isActive     Boolean  @default(true)
  isPopular    Boolean  @default(false)
  displayOrder Int      @default(999)
  lastSyncedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([brand])
  @@index([isActive, isPopular])
  @@index([category])
}

model PriceEvent {
  id                String     @id @default(uuid())
  name              String
  isActive          Boolean    @default(false)
  displayMarkupRate Float
  actualMarkupRate  Float
  scope             EventScope @default(ALL)
  scopeValue        String?
  scopeItemCodes    String[]   @default([])
  startAt           DateTime?
  endAt             DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([isActive])
}

model Order {
  id             String      @id @default(uuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id])
  game           String
  gameUserId     String
  gameServerId   String?
  itemCode       String
  itemName       String
  amount         Int
  status         OrderStatus @default(PENDING)
  paymentMethod  String?
  paymentUrl     String?
  paymentRef     String?     @unique
  supplierRef    String?     @unique
  adminNote      String?
  discordGuildId String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  expiredAt      DateTime
  point          Point?

  @@index([userId])
  @@index([status])
  @@index([paymentRef])
}

model ServerReferral {
  id            String   @id @default(uuid())
  guildId       String   @unique
  inviterUserId String
  inviter       User     @relation(fields: [inviterUserId], references: [id])
  createdAt     DateTime @default(now())

  @@index([inviterUserId])
}

model Point {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  orderId     String?   @unique
  order       Order?    @relation(fields: [orderId], references: [id])
  type        PointType
  amount      Int
  description String
  expiredAt   DateTime
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([expiredAt])
}

model Feedback {
  id        String          @id @default(uuid())
  ticketId  String          @unique
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  message   String
  status    FeedbackStatus  @default(OPEN)
  replies   FeedbackReply[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([userId])
  @@index([status])
}

model FeedbackReply {
  id         String   @id @default(uuid())
  feedbackId String
  feedback   Feedback @relation(fields: [feedbackId], references: [id])
  message    String
  fromAdmin  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([feedbackId])
}

enum FeedbackStatus {
  OPEN
  REPLIED
  CLOSED
}

enum EventScope {
  ALL
  BRAND
  ITEMS
}

enum Platform {
  TELEGRAM
  DISCORD
  WHATSAPP
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SUCCESS
  FAILED
  EXPIRED
  CANCELLED
}

enum PointType {
  EARNED
  REDEEMED
  EXPIRED
}
